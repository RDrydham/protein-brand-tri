# FTP/SFTP Credentials for automatic deployment
# Duplicate this file as '.env' and fill in your details

DEPLOY_HOST=ftp.therealinside.com
DEPLOY_PORT=21
DEPLOY_USER=your_username
DEPLOY_PASS=your_password
DEPLOY_REMOTE_DIR=/public_html
DEPLOY_PROTOCOL=ftp

# For SFTP (Port 22), install paramiko: 'pip install paramiko'
# and set:
# DEPLOY_PORT=22
# DEPLOY_PROTOCOL=sftp
