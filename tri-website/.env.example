# Database configuration (Prisma standard)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tri_db?schema=public"

# Server configuration
PORT=3000
NODE_ENV=development

# JWT Secret for Auth sessions
JWT_SECRET="your_jwt_secret_key_here_change_in_production"
JWT_EXPIRES_IN="7d"

# Razorpay credentials (Test Mode keys)
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_key_secret"

# SMTP Email configurations
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM='"TRI Performance" <leads@therealinside.com>'
