# ==============================================================
#  TRI Performance — Apache .htaccess
#  For Hostinger Premium Shared Hosting (Apache + mod_rewrite)
#  FIXED: 2026-06-11 — HTTPS redirect, bot protection, caching
# ==============================================================

# ── Security: Block direct access to sensitive files ──────────
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

<Files "leads_backup.json">
    Order Allow,Deny
    Deny from all
</Files>

<Files "*.csv">
    Order Allow,Deny
    Deny from all
</Files>

<Files "*.log">
    Order Allow,Deny
    Deny from all
</Files>

# ── Block bad bots from flooding API (stops 429 from bot abuse)
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (scrapy|AhrefsBot|SemrushBot|MJ12bot|DotBot|BLEXBot) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} ^-?$
    RewriteRule ^api/ - [F,L]
</IfModule>


# ── Disable directory listing + enable symlinks ───────────────
Options -Indexes +FollowSymLinks


# ── Enable URL rewriting ──────────────────────────────────────
RewriteEngine On


# ── Force HTTPS — CRITICAL FIX (enables loading on all devices)
# IMPORTANT: In Hostinger hPanel, go to Security -> SSL -> make
# sure "Force HTTPS" toggle is OFF (to avoid double redirect).
# This rule below handles the redirect instead.
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTP:CF-Visitor} !'"scheme":"https"'
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]


# ── Allow direct access to real files & directories ───────────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]


# ── Route: POST /api/save-lead → submit-lead.php ─────────────
RewriteCond %{REQUEST_METHOD} POST [NC]
RewriteRule ^api/save-lead/?$ submit-lead.php [L,QSA]

RewriteCond %{REQUEST_METHOD} POST [NC]
RewriteRule ^save-lead/?$ submit-lead.php [L,QSA]

# ── Route: POST /api/subscribe → subscribe.php ───────────────
RewriteCond %{REQUEST_METHOD} POST [NC]
RewriteRule ^api/subscribe/?$ subscribe.php [L,QSA]

# ── Route: POST /api/contact → contact-handler.php ───────────
RewriteCond %{REQUEST_METHOD} POST [NC]
RewriteRule ^api/contact/?$ contact-handler.php [L,QSA]


# ── Route: Clean URLs for static HTML pages ───────────────────
RewriteRule ^about/?$        about.html        [L,NC]
RewriteRule ^inside/?$       inside.html       [L,NC]
RewriteRule ^lab/?$          lab-reports.html  [L,NC]
RewriteRule ^lab-reports/?$  lab-reports.html  [L,NC]
RewriteRule ^shop/?$         shop.html         [L,NC]
RewriteRule ^contact/?$      contact.html      [L,NC]

RewriteCond %{REQUEST_URI} ^/?$
RewriteCond %{DOCUMENT_ROOT}/index.html -f
RewriteRule ^$ index.html [L]


# ── MIME Types ────────────────────────────────────────────────
AddType application/javascript          .js
AddType text/css                        .css
AddType image/svg+xml                   .svg
AddType image/webp                      .webp
AddType image/avif                      .avif
AddType font/woff                       .woff
AddType font/woff2                      .woff2
AddType video/mp4                       .mp4
AddType video/webm                      .webm


# ── Browser Caching ───────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 month"
    ExpiresByType text/html                     "access plus 1 hour"
    ExpiresByType text/css                      "access plus 6 months"
    ExpiresByType application/javascript        "access plus 6 months"
    ExpiresByType text/javascript               "access plus 6 months"
    ExpiresByType image/jpeg                    "access plus 1 year"
    ExpiresByType image/png                     "access plus 1 year"
    ExpiresByType image/webp                    "access plus 1 year"
    ExpiresByType image/avif                    "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 1 year"
    ExpiresByType image/x-icon                  "access plus 1 year"
    ExpiresByType font/woff                     "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
    ExpiresByType video/mp4                     "access plus 6 months"
    ExpiresByType video/webm                    "access plus 6 months"
    ExpiresByType application/json              "access plus 1 hour"
</IfModule>


# ── Cache-Control Headers (tells Cloudflare to cache aggressively)
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|woff|woff2|svg|webp|avif|jpg|jpeg|png|gif|mp4|webm|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header set Vary "Accept-Encoding"
    </FilesMatch>

    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600, s-maxage=86400, stale-while-revalidate=86400"
    </FilesMatch>

    Header always set X-Content-Type-Options  "nosniff"
    Header always set X-Frame-Options         "SAMEORIGIN"
    Header always set X-XSS-Protection        "1; mode=block"
    Header always set Referrer-Policy         "strict-origin-when-cross-origin"

    <FilesMatch "\.(php)$">
        Header set Access-Control-Allow-Origin "https://therealinside.com"
        Header set Access-Control-Allow-Methods "POST, OPTIONS"
    </FilesMatch>
</IfModule>


# ── Enable Gzip Compression ───────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2
</IfModule>


# ── PHP Settings (Hostinger shared hosting) ───────────────────
<IfModule mod_php.c>
    php_value  memory_limit       128M
    php_value  max_execution_time 30
    php_value  upload_max_filesize 8M
    php_value  post_max_size       10M
    php_flag   display_errors     Off
    php_flag   log_errors         On
</IfModule>
